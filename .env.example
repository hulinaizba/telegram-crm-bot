# Скопируйте этот файл в .env и заполните реальными значениями.
# .env никогда не должен попадать в git — он уже в .gitignore.

# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=

# Telegram user_id операторов через запятую (узнать свой можно у @userinfobot)
ALLOWED_USERS=111111111,222222222

# --- Google Sheets ---
# ID таблицы (из её URL: https://docs.google.com/spreadsheets/d/ЭТОТ_ID/edit)
SPREADSHEET_ID=
# Путь к JSON-ключу сервисного аккаунта Google (см. README, раздел «Настройка Google Sheets»)
GOOGLE_CREDENTIALS_FILE=service-account.json
# Название листа с клиентами внутри таблицы
WORKSHEET_NAME=Клиенты
# Название листа для журнала идей (/idea, /ideas) — создаётся автоматически
IDEAS_WORKSHEET_NAME=Идеи

# --- Напоминания и авто-обновление ---
# Время ежедневного напоминания операторам, формат ЧЧ:ММ (пусто — отключить)
REMINDER_TIME=08:00
# Часовой пояс для REMINDER_TIME (IANA-имя). НЕ зависит от того, где стоит
# сервер, — важно, если бот и операторы в разных часовых поясах.
REMINDER_TIMEZONE=Asia/Jerusalem
# Как часто (в минутах) бот сам перечитывает таблицу; 0 — отключить
RELOAD_INTERVAL_MINUTES=10

# --- Логирование ---
LOG_LEVEL=INFO
LOG_FILE=bot.log
LOG_MAX_BYTES=1000000
LOG_BACKUP_COUNT=3
